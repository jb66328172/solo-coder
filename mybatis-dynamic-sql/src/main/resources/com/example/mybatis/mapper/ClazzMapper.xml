<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatis.mapper.ClazzMapper">

    <resultMap id="ClazzWithDetailResultMap" type="Clazz">
        <id property="id" column="c_id"/>
        <result property="name" column="c_name"/>
        <result property="grade" column="grade"/>
        <result property="headTeacherId" column="head_teacher_id"/>
        <association property="headTeacher" javaType="Teacher">
            <id property="id" column="ht_id"/>
            <result property="name" column="ht_name"/>
            <result property="age" column="ht_age"/>
            <result property="title" column="ht_title"/>
            <result property="deptId" column="ht_dept_id"/>
        </association>
        <collection property="courses" ofType="Course">
            <id property="id" column="co_id"/>
            <result property="name" column="co_name"/>
            <result property="hours" column="hours"/>
            <result property="teacherId" column="co_teacher_id"/>
            <result property="classId" column="co_class_id"/>
            <association property="teacher" javaType="Teacher">
                <id property="id" column="ct_id"/>
                <result property="name" column="ct_name"/>
                <result property="age" column="ct_age"/>
                <result property="title" column="ct_title"/>
                <result property="deptId" column="ct_dept_id"/>
            </association>
        </collection>
    </resultMap>

    <resultMap id="ClazzWithHeadTeacherResultMap" type="Clazz">
        <id property="id" column="c_id"/>
        <result property="name" column="c_name"/>
        <result property="grade" column="grade"/>
        <result property="headTeacherId" column="head_teacher_id"/>
        <association property="headTeacher" javaType="Teacher">
            <id property="id" column="ht_id"/>
            <result property="name" column="ht_name"/>
        </association>
    </resultMap>

    <select id="selectClazzWithDetailById" resultMap="ClazzWithDetailResultMap">
        SELECT c.id AS c_id,
               c.name AS c_name,
               c.grade AS grade,
               c.head_teacher_id AS head_teacher_id,
               ht.id AS ht_id,
               ht.name AS ht_name,
               ht.age AS ht_age,
               ht.title AS ht_title,
               ht.dept_id AS ht_dept_id,
               co.id AS co_id,
               co.name AS co_name,
               co.hours AS hours,
               co.teacher_id AS co_teacher_id,
               co.class_id AS co_class_id,
               ct.id AS ct_id,
               ct.name AS ct_name,
               ct.age AS ct_age,
               ct.title AS ct_title,
               ct.dept_id AS ct_dept_id
        FROM clazz c
        LEFT JOIN teacher ht ON c.head_teacher_id = ht.id
        LEFT JOIN course co ON c.id = co.class_id
        LEFT JOIN teacher ct ON co.teacher_id = ct.id
        WHERE c.id = #{id}
    </select>

    <select id="selectAllWithHeadTeacher" resultMap="ClazzWithHeadTeacherResultMap">
        SELECT c.id AS c_id,
               c.name AS c_name,
               c.grade AS grade,
               c.head_teacher_id AS head_teacher_id,
               ht.id AS ht_id,
               ht.name AS ht_name
        FROM clazz c
        LEFT JOIN teacher ht ON c.head_teacher_id = ht.id
        ORDER BY c.id
    </select>

</mapper>
