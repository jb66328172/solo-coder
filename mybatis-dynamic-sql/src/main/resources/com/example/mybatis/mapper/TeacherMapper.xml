<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatis.mapper.TeacherMapper">

    <resultMap id="TeacherResultMap" type="Teacher">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="age" column="age"/>
        <result property="title" column="title"/>
        <result property="deptId" column="dept_id"/>
    </resultMap>

    <select id="selectByDeptAndAgeRange" resultMap="TeacherResultMap">
        SELECT id, name, age, title, dept_id
        FROM teacher
        WHERE dept_id = #{deptId}
          AND age BETWEEN #{minAge} AND #{maxAge}
    </select>

    <select id="selectByCondition" parameterType="Teacher" resultMap="TeacherResultMap">
        SELECT id, name, age, title, dept_id
        FROM teacher
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="deptId != null">
                AND dept_id = #{deptId}
            </if>
            <if test="title != null and title != ''">
                AND title = #{title}
            </if>
            <if test="(name == null or name == '') and deptId == null and (title == null or title == '')">
                AND 1 = 0
            </if>
        </where>
    </select>

    <delete id="deleteBatchByIds">
        DELETE FROM teacher
        WHERE id IN
        <if test="ids != null and ids.size() > 0">
            <foreach collection="ids" item="id" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="ids == null or ids.size() == 0">
            (NULL)
        </if>
    </delete>

</mapper>
