<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatis.mapper.CourseMapper">

    <resultMap id="CourseWithDetailResultMap" type="Course">
        <id property="id" column="co_id"/>
        <result property="name" column="co_name"/>
        <result property="hours" column="hours"/>
        <result property="teacherId" column="teacher_id"/>
        <result property="classId" column="class_id"/>
        <association property="teacher" javaType="Teacher">
            <id property="id" column="t_id"/>
            <result property="name" column="t_name"/>
            <result property="age" column="t_age"/>
            <result property="title" column="t_title"/>
            <result property="deptId" column="t_dept_id"/>
        </association>
        <association property="clazz" javaType="Clazz">
            <id property="id" column="c_id"/>
            <result property="name" column="c_name"/>
            <result property="grade" column="grade"/>
            <result property="headTeacherId" column="head_teacher_id"/>
        </association>
    </resultMap>

    <resultMap id="CourseSimpleResultMap" type="Course">
        <id property="id" column="co_id"/>
        <result property="name" column="co_name"/>
        <result property="hours" column="hours"/>
        <result property="teacherId" column="teacher_id"/>
        <result property="classId" column="class_id"/>
        <association property="clazz" javaType="Clazz">
            <id property="id" column="c_id"/>
            <result property="name" column="c_name"/>
            <result property="grade" column="grade"/>
        </association>
    </resultMap>

    <select id="selectCourseWithDetailById" resultMap="CourseWithDetailResultMap">
        SELECT co.id AS co_id,
               co.name AS co_name,
               co.hours AS hours,
               co.teacher_id AS teacher_id,
               co.class_id AS class_id,
               t.id AS t_id,
               t.name AS t_name,
               t.age AS t_age,
               t.title AS t_title,
               t.dept_id AS t_dept_id,
               c.id AS c_id,
               c.name AS c_name,
               c.grade AS grade,
               c.head_teacher_id AS head_teacher_id
        FROM course co
        LEFT JOIN teacher t ON co.teacher_id = t.id
        LEFT JOIN clazz c ON co.class_id = c.id
        WHERE co.id = #{id}
    </select>

    <select id="selectByTeacherId" resultMap="CourseSimpleResultMap">
        SELECT co.id AS co_id,
               co.name AS co_name,
               co.hours AS hours,
               co.teacher_id AS teacher_id,
               co.class_id AS class_id,
               c.id AS c_id,
               c.name AS c_name,
               c.grade AS grade
        FROM course co
        LEFT JOIN clazz c ON co.class_id = c.id
        WHERE co.teacher_id = #{teacherId}
        ORDER BY co.id
    </select>

</mapper>
